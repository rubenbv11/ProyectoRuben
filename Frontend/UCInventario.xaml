<UserControl x:Class="ProyectoRuben.Frontend.UCInventario"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             Background="{StaticResource LightGrayBrush}">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,24">
            <TextBlock Text="Control de Stock e Inventario" FontSize="28" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}"/>
            <TextBlock Text="Actualiza las cantidades de tus productos haciendo doble clic en la celda 'Stock'" FontSize="14" Foreground="{StaticResource TextLightBrush}" Margin="0,4,0,0"/>
        </StackPanel>

        <Border Grid.Row="1" Background="White" CornerRadius="12" Padding="16">
            <Border.Effect>
                <DropShadowEffect BlurRadius="15" ShadowDepth="2" Direction="270" Color="#000000" Opacity="0.08"/>
            </Border.Effect>

            <DataGrid ItemsSource="{Binding ListaProductos}" AutoGenerateColumns="False" CanUserAddRows="False" 
                      Background="Transparent" BorderThickness="0" RowHeight="50" HeadersVisibility="Column"
                      GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="{StaticResource MediumGrayBrush}">

                <DataGrid.Columns>
                    <DataGridTextColumn Header="Producto" Binding="{Binding Nombre}" IsReadOnly="True" Width="2*"/>
                    <DataGridTextColumn Header="Proveedor" Binding="{Binding Proveedor}" IsReadOnly="True" Width="*"/>
                    <DataGridTextColumn Header="Precio" Binding="{Binding Precio, StringFormat='{}{0:F2} €'}" IsReadOnly="True" Width="*"/>
                    
                    <DataGridTemplateColumn Header="Stock Actual" Width="*">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Border CornerRadius="6" Padding="8,4" HorizontalAlignment="Left">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="#E8F5E9"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding AlertaStock}" Value="True">
                                                    <Setter Property="Background" Value="#FFEBEE"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <TextBlock Text="{Binding Cantidad}" FontWeight="Bold" HorizontalAlignment="Center">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="#2E7D32"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding AlertaStock}" Value="True">
                                                        <Setter Property="Foreground" Value="#C62828"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Border>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                        <DataGridTemplateColumn.CellEditingTemplate>
                            <DataTemplate>
                                <TextBox Text="{Binding Cantidad, UpdateSourceTrigger=PropertyChanged}" 
                                         VerticalAlignment="Center" HorizontalAlignment="Stretch"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellEditingTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTemplateColumn Header="Acción" Width="100">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Button Content="Guardar" 
                                        Command="{Binding DataContext.ActualizarStockCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}" 
                                        CommandParameter="{Binding}"
                                        Style="{StaticResource MaterialDesignOutlinedButton}" 
                                        Foreground="{StaticResource PrimaryBrush}" 
                                        BorderBrush="{StaticResource PrimaryBrush}" 
                                        Height="30" Padding="8,0" Cursor="Hand"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</UserControl>