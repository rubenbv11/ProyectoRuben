<UserControl x:Class="ProyectoRuben.Frontend.UCProductos"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             mc:Ignorable="d" 
             Background="{StaticResource LightGrayBrush}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ENCABEZADO -->
        <Border Grid.Row="0" Background="White" Padding="32,24" BorderThickness="0,0,0,1" BorderBrush="{StaticResource MediumGrayBrush}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Título y descripción -->
                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <TextBlock Text="Catálogo de Productos" 
                               FontSize="28" 
                               FontWeight="SemiBold" 
                               Foreground="{StaticResource TextBrush}"/>

                    <TextBlock Text="Gestiona el inventario y stock de productos"
                               FontSize="13"
                               Foreground="{StaticResource TextLightBrush}"
                               Margin="0,4,0,0"/>
                </StackPanel>

                <!-- Botón Nuevo Producto -->
                <Button Grid.Column="1" 
        Style="{StaticResource MaterialDesignRaisedButton}"
        VerticalAlignment="Center"
        Background="{StaticResource AccentBrush}"
        BorderBrush="{StaticResource AccentBrush}"
        Foreground="White"
        Height="40"
        Padding="16,0"
        Cursor="Hand"
        FontSize="13"
        FontWeight="SemiBold"
        Command="{Binding AgregarProductoCommand}">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <materialDesign:PackIcon Kind="Plus" Width="18" Height="18" Margin="0,0,8,0" VerticalAlignment="Center"/>
                        <TextBlock Text="Nuevo Producto" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </Grid>
        </Border>

        <!-- CONTENIDO PRINCIPAL -->
        <Grid Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- BARRA DE BÚSQUEDA -->
            <Border Grid.Row="0" Background="White" Padding="32,16" BorderThickness="0,0,0,1" BorderBrush="{StaticResource MediumGrayBrush}">
                <TextBox Text="{Binding FiltroNombre, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         Height="40"
                         Padding="12,8"
                         Foreground="{StaticResource TextBrush}"
                         Background="White"
                         BorderBrush="{StaticResource MediumGrayBrush}"
                         BorderThickness="1"
                         FontSize="13"
                         MaxWidth="400"
                         HorizontalAlignment="Left">
                    <TextBox.Template>
                        <ControlTemplate TargetType="TextBox">
                            <Border BorderBrush="{TemplateBinding BorderBrush}" 
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="6"
                                    Background="{TemplateBinding Background}">
                                <Grid>
                                    <materialDesign:PackIcon Kind="Magnify" 
                                                             Foreground="{StaticResource TextLightBrush}"
                                                             Width="20" Height="20"
                                                             Margin="10,0,0,0"
                                                             VerticalAlignment="Center"/>
                                    <ScrollViewer Margin="36,0,10,0" x:Name="PART_ContentHost" VerticalAlignment="Center"/>
                                </Grid>
                            </Border>
                        </ControlTemplate>
                    </TextBox.Template>
                </TextBox>
            </Border>

            <!-- LISTA DE PRODUCTOS O ESTADO VACÍO -->
            <Grid Grid.Row="1">
                <!-- Estado Vacío -->
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Visibility="{Binding EstaVacio, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <Border Width="80" Height="80" Background="{StaticResource MediumGrayBrush}" CornerRadius="40" HorizontalAlignment="Center" Margin="0,0,0,16">
                        <materialDesign:PackIcon Kind="Package" 
                                                 Foreground="White"
                                                 Width="40" Height="40"
                                                 VerticalAlignment="Center"
                                                 HorizontalAlignment="Center"/>
                    </Border>

                    <TextBlock Text="Sin productos registrados" 
                               FontSize="18" 
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextBrush}"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,8"/>

                    <TextBlock Text="Comienza agregando tu primer producto"
                               FontSize="13"
                               Foreground="{StaticResource TextLightBrush}"
                               HorizontalAlignment="Center"/>
                </StackPanel>

                <!-- Lista de Productos -->
                <ScrollViewer Visibility="{Binding EstaVacio, Converter={StaticResource BooleanToVisibilityConverter}, ConverterParameter=Invert}">
                    <ItemsControl ItemsSource="{Binding ListaProductosView}" Padding="32,24">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel Orientation="Horizontal" Width="{Binding ActualWidth, RelativeSource={RelativeSource AncestorType=ItemsControl}}" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>

                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <!-- TARJETA DE PRODUCTO -->
                                <Border Width="320" Margin="0,0,24,24"
                                        Background="White"
                                        CornerRadius="12"
                                        Padding="20">
                                    <Border.Effect>
                                        <DropShadowEffect BlurRadius="15" ShadowDepth="2" Direction="270" Color="#000000" Opacity="0.08"/>
                                    </Border.Effect>

                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <!-- NOMBRE DEL PRODUCTO -->
                                        <TextBlock Grid.Row="0"
                                                   Text="{Binding Nombre}"
                                                   FontSize="16"
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource TextBrush}"
                                                   TextTrimming="CharacterEllipsis"
                                                   Margin="0,0,0,8"/>

                                        <!-- PROVEEDOR Y PRECIO -->
                                        <Grid Grid.Row="1" Margin="0,0,0,12">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <StackPanel Grid.Column="0" Orientation="Horizontal">
                                                <materialDesign:PackIcon Kind="Truck" 
                                                                         Foreground="{StaticResource TextLightBrush}"
                                                                         Width="14" Height="14"
                                                                         Margin="0,0,6,0"
                                                                         VerticalAlignment="Center"/>
                                                <TextBlock Text="{Binding Proveedor}" 
                                                           FontSize="12"
                                                           Foreground="{StaticResource TextLightBrush}"
                                                           TextTrimming="CharacterEllipsis"/>
                                            </StackPanel>

                                            <Border Grid.Column="1" 
                                                    Padding="10,4" 
                                                    Background="{StaticResource LightGrayBrush}" 
                                                    CornerRadius="4">
                                                <TextBlock Text="{Binding Precio, StringFormat='C'}" 
                                                           FontSize="12"
                                                           FontWeight="SemiBold"
                                                           Foreground="{StaticResource AccentBrush}"/>
                                            </Border>
                                        </Grid>

                                        <!-- SEPARADOR -->
                                        <Rectangle Grid.Row="2" Height="1" Fill="{StaticResource MediumGrayBrush}" Margin="0,0,0,12" VerticalAlignment="Top"/>

                                        <!-- INDICADOR DE STOCK -->
                                        <Border Grid.Row="3" Padding="12,8" CornerRadius="6" Margin="0,0,0,12">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="{StaticResource LightGrayBrush}"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Cantidad, Converter={StaticResource StockBajoConverter}}" Value="True">
                                                            <Setter Property="Background" Value="#FFEBEE"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>

                                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                <materialDesign:PackIcon Kind="Package" 
                                                                         Foreground="{StaticResource TextBrush}"
                                                                         Width="16" Height="16"
                                                                         Margin="0,0,8,0">
                                                    <materialDesign:PackIcon.Style>
                                                        <Style TargetType="materialDesign:PackIcon">
                                                            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Cantidad, Converter={StaticResource StockBajoConverter}}" Value="True">
                                                                    <Setter Property="Foreground" Value="#E65100"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </materialDesign:PackIcon.Style>
                                                </materialDesign:PackIcon>

                                                <TextBlock Text="Stock: ">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="FontSize" Value="12"/>
                                                            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Cantidad, Converter={StaticResource StockBajoConverter}}" Value="True">
                                                                    <Setter Property="Foreground" Value="#D32F2F"/>
                                                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>

                                                <TextBlock Text="{Binding Cantidad}">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="FontSize" Value="12"/>
                                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                                            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Cantidad, Converter={StaticResource StockBajoConverter}}" Value="True">
                                                                    <Setter Property="Foreground" Value="#D32F2F"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>

                                                <TextBlock Text=" unidades" FontSize="11" Foreground="{StaticResource TextLightBrush}" Margin="2,0,0,0"/>

                                                <!-- Icono de alerta si stock es bajo -->
                                                <materialDesign:PackIcon Kind="AlertCircleOutline" 
                                                                         Foreground="#E65100"
                                                                         Width="16" Height="16"
                                                                         Margin="8,0,0,0"
                                                                         Visibility="{Binding Cantidad, Converter={StaticResource StockBajoConverter}, ConverterParameter=Invert}"/>
                                            </StackPanel>
                                        </Border>

                                        <!-- BOTONES DE ACCIÓN -->
                                        <StackPanel Grid.Row="4" Orientation="Horizontal">
                                            <!-- Editar -->
                                            <Button Width="40" Height="40"
                                                    Background="{StaticResource LightGrayBrush}"
                                                    Foreground="{StaticResource TextBrush}"
                                                    BorderThickness="0"
                                                    Cursor="Hand"
                                                    ToolTip="Editar producto"
                                                    Margin="0,0,8,0"
                                                    Command="{Binding DataContext.EditarProductoCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                    CommandParameter="{Binding}">
                                                <materialDesign:PackIcon Kind="Pencil" Width="18" Height="18"/>
                                            </Button>

                                            <!-- Desactivar -->
                                            <Button Width="40" Height="40"
                                                    Background="#FFE0E0"
                                                    Foreground="#D63031"
                                                    BorderThickness="0"
                                                    Cursor="Hand"
                                                    ToolTip="Desactivar producto"
                                                    Margin="Auto,0,0,0"
                                                    Command="{Binding DataContext.DesactivarProductoCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                    CommandParameter="{Binding Id}">
                                                <materialDesign:PackIcon Kind="Delete" Width="18" Height="18"/>
                                            </Button>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
