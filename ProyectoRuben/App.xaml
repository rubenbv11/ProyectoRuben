<Application x:Class="ProyectoRuben.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:ProyectoRuben"
             xmlns:converters="clr-namespace:ProyectoRuben.Frontend.Converters"
             xmlns:mat="http://materialdesigninxaml.net/winfx/xaml/themes">

    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>

                <!-- Material Design principal - Neutro Moderno -->
                <mat:BundledTheme BaseTheme="Light"
                                  PrimaryColor="Grey"/>

                <!-- Recursos obligatorios de Material Design -->
                <ResourceDictionary Source="pack://application:,,,/MaterialDesignThemes.Wpf;component/Themes/MaterialDesign2.Defaults.xaml" />

                <!-- Tu tema personalizado -->
                <ResourceDictionary Source="Estilos/Theme.xaml" />

            </ResourceDictionary.MergedDictionaries>

            <!-- Recursos generales -->
            <DropShadowEffect x:Key="DropShadow" BlurRadius="5" ShadowDepth="2"/>

            <!-- Converters personalizados -->
            <converters:StringToFirstCharConverter x:Key="StringToFirstCharConverter"/>
            <converters:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
            <converters:StockBajoConverter x:Key="StockBajoConverter"/>
        </ResourceDictionary>
    </Application.Resources>
</Application>
