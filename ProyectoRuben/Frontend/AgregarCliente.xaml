<Window x:Class="ProyectoRuben.Frontend.AgregarCliente"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        mc:Ignorable="d"
        Loaded="AgregarCliente_Loaded"
        Title="Nuevo Cliente" Height="420" Width="400"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize"
        Background="#F5F6F7">

    <Border Margin="20" Background="White" CornerRadius="12" Padding="24">
        <Border.Effect>
            <DropShadowEffect BlurRadius="15" ShadowDepth="2" Direction="270" Color="#000000" Opacity="0.08"/>
        </Border.Effect>

        <StackPanel VerticalAlignment="Center">

            <TextBlock Text="Crear Nuevo Cliente" 
                       FontSize="22"
                       FontWeight="SemiBold"
                       Foreground="#2D3436"
                       HorizontalAlignment="Center" 
                       Margin="0,0,0,24"/>

            <TextBlock Text="Nombre" FontSize="12" Foreground="#636E72" Margin="0,0,0,4"/>
            <TextBox x:Name="TxtNombre"
                     Style="{StaticResource MaterialDesignFloatingHintTextBox}"
                     materialDesign:HintAssist.Hint="Nombre del cliente"
                     Text="{Binding ClienteNuevo.Nombre, UpdateSourceTrigger=PropertyChanged}"
                     Height="40"
                     Padding="12,8"
                     Foreground="#2D3436"
                     Background="White"
                     BorderBrush="#DFE6E9"
                     BorderThickness="1"
                     Margin="0,0,0,16"/>

            <TextBlock Text="Teléfono" FontSize="12" Foreground="#636E72" Margin="0,0,0,4"/>
            <TextBox x:Name="TxtTelefono"
                     Style="{StaticResource MaterialDesignFloatingHintTextBox}"
                     materialDesign:HintAssist.Hint="Teléfono"
                     Text="{Binding ClienteNuevo.Telefono, UpdateSourceTrigger=PropertyChanged}"
                     Height="40"
                     Padding="12,8"
                     Foreground="#2D3436"
                     Background="White"
                     BorderBrush="#DFE6E9"
                     BorderThickness="1"
                     Margin="0,0,0,16"/>

            <TextBlock Text="Email" FontSize="12" Foreground="#636E72" Margin="0,0,0,4"/>
            <TextBox x:Name="TxtEmail"
                     Style="{StaticResource MaterialDesignFloatingHintTextBox}"
                     materialDesign:HintAssist.Hint="Email"
                     Text="{Binding ClienteNuevo.Email, UpdateSourceTrigger=PropertyChanged}"
                     Height="40"
                     Padding="12,8"
                     Foreground="#2D3436"
                     Background="White"
                     BorderBrush="#DFE6E9"
                     BorderThickness="1"
                     Margin="0,0,0,24"/>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,24,0,0">
                <Button Content="Cancelar" 
                        Background="Transparent"
                        Foreground="#636E72"
                        BorderThickness="1"
                        BorderBrush="#DFE6E9"
                        Padding="20,10"
                        Cursor="Hand"
                        IsCancel="True" 
                        Click="Cancelar_Click"/>

                <Button Content="GUARDAR" 
                        Style="{StaticResource MaterialDesignRaisedButton}"
                        Background="#D4A574"
                        Foreground="White"
                        Padding="24,10"
                        Cursor="Hand"
                        Margin="12,0,0,0"
                        IsDefault="True" 
                        Click="Guardar_Click"/>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
