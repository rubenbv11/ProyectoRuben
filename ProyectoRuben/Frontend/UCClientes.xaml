<UserControl x:Class="ProyectoRuben.Frontend.UCClientes"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:converters="clr-namespace:ProyectoRuben.Frontend.Converters"
             mc:Ignorable="d" 
             Background="{StaticResource LightGrayBrush}">
    <UserControl.Resources>
        <converters:StringToFirstCharConverter x:Key="StringToFirstCharConverter" />
        <converters:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ENCABEZADO -->
        <Border Grid.Row="0" Background="White" Padding="32,24" BorderThickness="0,0,0,1" BorderBrush="{StaticResource MediumGrayBrush}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Título y descripción -->
                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <TextBlock Text="Gestión de Clientes" 
                               FontSize="28" 
                               FontWeight="SemiBold" 
                               Foreground="{StaticResource TextBrush}"
                               FontFamily="pack://application:,,,/ProyectoRuben;component/Fonts/#Montserrat"/>

                    <TextBlock Text="Administra y visualiza el registro de clientes de la peluquería"
                               FontSize="13"
                               Foreground="{StaticResource TextLightBrush}"
                               Margin="0,4,0,0"
                               FontFamily="pack://application:,,,/ProyectoRuben;component/Fonts/#Montserrat"/>
                </StackPanel>

                <!-- Botón Nueva Cliente -->
                <Button Grid.Column="1" 
                        VerticalAlignment="Center"
                        Background="{StaticResource AccentBrush}"
                        Foreground="White"
                        Padding="20,12"
                        BorderThickness="0"
                        Cursor="Hand"
                        FontSize="13"
                        FontWeight="SemiBold"
                        Command="{Binding AgregarClienteCommand}"
                        FontFamily="pack://application:,,,/ProyectoRuben;component/Fonts/#Montserrat">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <materialDesign:PackIcon Kind="Plus" Width="18" Height="18" Margin="0,0,8,0" VerticalAlignment="Center"/>
                        <TextBlock Text="Nuevo Cliente"/>
                    </StackPanel>
                </Button>
            </Grid>
        </Border>

        <!-- CONTENIDO PRINCIPAL -->
        <Grid Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- BARRA DE BÚSQUEDA -->
            <Border Grid.Row="0" Background="White" Padding="32,16" BorderThickness="0,0,0,1" BorderBrush="{StaticResource MediumGrayBrush}">
                <TextBox Text="{Binding FiltroNombre, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         Height="40"
                         Padding="12,8"
                         Foreground="{StaticResource TextBrush}"
                         Background="White"
                         BorderBrush="{StaticResource MediumGrayBrush}"
                         BorderThickness="1"
                         FontSize="13"
                         FontFamily="pack://application:,,,/ProyectoRuben;component/Fonts/#Montserrat"
                         MaxWidth="400"
                         HorizontalAlignment="Left">
                    <TextBox.Template>
                        <ControlTemplate TargetType="TextBox">
                            <Border BorderBrush="{TemplateBinding BorderBrush}" 
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="6"
                                    Background="{TemplateBinding Background}">
                                <Grid>
                                    <materialDesign:PackIcon Kind="Magnify" 
                                                             Foreground="{StaticResource TextLightBrush}"
                                                             Width="20" Height="20"
                                                             Margin="10,0,0,0"
                                                             VerticalAlignment="Center"/>
                                    <ScrollViewer Margin="36,0,10,0" x:Name="PART_ContentHost" VerticalAlignment="Center"/>
                                </Grid>
                            </Border>
                        </ControlTemplate>
                    </TextBox.Template>
                </TextBox>
            </Border>

            <!-- LISTA DE CLIENTES O ESTADO VACÍO -->
            <Grid Grid.Row="1">
                <!-- Estado Vacío -->
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Visibility="{Binding EstaVacio, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <Border Width="80" Height="80" Background="{StaticResource MediumGrayBrush}" CornerRadius="40" HorizontalAlignment="Center" Margin="0,0,0,16">
                        <materialDesign:PackIcon Kind="PeopleOutline" 
                                                 Foreground="White"
                                                 Width="40" Height="40"
                                                 VerticalAlignment="Center"
                                                 HorizontalAlignment="Center"/>
                    </Border>

                    <TextBlock Text="Sin clientes registrados" 
                               FontSize="18" 
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextBrush}"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,8"
                               FontFamily="pack://application:,,,/ProyectoRuben;component/Fonts/#Montserrat"/>

                    <TextBlock Text="Comienza agregando tu primer cliente"
                               FontSize="13"
                               Foreground="{StaticResource TextLightBrush}"
                               HorizontalAlignment="Center"
                               FontFamily="pack://application:,,,/ProyectoRuben;component/Fonts/#Montserrat"/>
                </StackPanel>

                <!-- Lista de Clientes -->
                <ScrollViewer Visibility="{Binding EstaVacio, Converter={StaticResource BooleanToVisibilityConverter}, ConverterParameter=Invert}">
                    <ItemsControl ItemsSource="{Binding ListaClientesView}" Padding="32,24">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel Orientation="Horizontal" Width="{Binding ActualWidth, RelativeSource={RelativeSource AncestorType=ItemsControl}}" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>

                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <!-- TARJETA DE CLIENTE -->
                                <Border Width="300" Margin="0,0,24,24"
                                        Background="White"
                                        CornerRadius="12"
                                        Padding="20">
                                    <Border.Effect>
                                        <DropShadowEffect BlurRadius="15" ShadowDepth="2" Direction="270" Color="#000000" Opacity="0.08"/>
                                    </Border.Effect>

                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <!-- AVATAR Y VIP BADGE -->
                                        <Grid Grid.Row="0" Margin="0,0,0,16">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="60"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <!-- Avatar circular -->
                                            <Ellipse Grid.Column="0" 
                                                     Width="60" Height="60"
                                                     Fill="{StaticResource AccentBrush}"/>

                                            <TextBlock Grid.Column="0"
                                                       Text="{Binding Nombre, Converter={StaticResource StringToFirstCharConverter}}"
                                                       Foreground="White"
                                                       FontSize="20"
                                                       FontWeight="SemiBold"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"
                                                       FontFamily="pack://application:,,,/ProyectoRuben;component/Fonts/#Montserrat"/>

                                            <!-- VIP Star Badge -->
                                            <Border Grid.Column="2" 
                                                    Width="32" Height="32"
                                                    Background="#FFD700"
                                                    CornerRadius="16"
                                                    VerticalAlignment="Top">
                                                <materialDesign:PackIcon Kind="Star" 
                                                                         Foreground="White"
                                                                         Width="18" Height="18"
                                                                         VerticalAlignment="Center"
                                                                         HorizontalAlignment="Center"/>
                                            </Border>
                                        </Grid>

                                        <!-- INFORMACIÓN CLIENTE -->
                                        <StackPanel Grid.Row="1" Margin="0,0,0,12">
                                            <TextBlock Text="{Binding Nombre}"
                                                       FontSize="15"
                                                       FontWeight="SemiBold"
                                                       Foreground="{StaticResource TextBrush}"
                                                       TextTrimming="CharacterEllipsis"
                                                       FontFamily="pack://application:,,,/ProyectoRuben;component/Fonts/#Montserrat"/>

                                            <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                                <materialDesign:PackIcon Kind="Phone" 
                                                                         Foreground="{StaticResource TextLightBrush}"
                                                                         Width="14" Height="14"
                                                                         Margin="0,0,6,0"/>
                                                <TextBlock Text="{Binding Telefono}" 
                                                           FontSize="12"
                                                           Foreground="{StaticResource TextLightBrush}"
                                                           FontFamily="pack://application:,,,/ProyectoRuben;component/Fonts/#Montserrat"/>
                                            </StackPanel>

                                            <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                                <materialDesign:PackIcon Kind="Email" 
                                                                         Foreground="{StaticResource TextLightBrush}"
                                                                         Width="14" Height="14"
                                                                         Margin="0,0,6,0"/>
                                                <TextBlock Text="{Binding Email}" 
                                                           FontSize="12"
                                                           Foreground="{StaticResource TextLightBrush}"
                                                           TextTrimming="CharacterEllipsis"
                                                           FontFamily="pack://application:,,,/ProyectoRuben;component/Fonts/#Montserrat"/>
                                            </StackPanel>
                                        </StackPanel>

                                        <!-- SEPARADOR -->
                                        <Rectangle Grid.Row="2" Height="1" Fill="{StaticResource MediumGrayBrush}" Margin="0,0,0,16" VerticalAlignment="Top"/>

                                        <!-- BOTONES DE ACCIÓN -->
                                        <StackPanel Grid.Row="3" Orientation="Horizontal">
                                            <!-- Editar -->
                                            <Button Width="40" Height="40"
                                                    Background="{StaticResource LightGrayBrush}"
                                                    Foreground="{StaticResource TextBrush}"
                                                    BorderThickness="0"
                                                    Cursor="Hand"
                                                    ToolTip="Editar cliente"
                                                    Margin="0,0,8,0"
                                                    Command="{Binding DataContext.EditarClienteCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                    CommandParameter="{Binding}">
                                                <materialDesign:PackIcon Kind="Pencil" Width="18" Height="18"/>
                                            </Button>

                                            <!-- Ver Historial -->
                                            <Button Width="40" Height="40"
                                                    Background="{StaticResource LightGrayBrush}"
                                                    Foreground="{StaticResource TextBrush}"
                                                    BorderThickness="0"
                                                    Cursor="Hand"
                                                    ToolTip="Ver historial"
                                                    Margin="0,0,8,0"
                                                    Command="{Binding DataContext.VerHistorialCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                    CommandParameter="{Binding}">
                                                <materialDesign:PackIcon Kind="History" Width="18" Height="18"/>
                                            </Button>

                                            <!-- Desactivar -->
                                            <Button Width="40" Height="40"
                                                    Background="#FFE0E0"
                                                    Foreground="#D63031"
                                                    BorderThickness="0"
                                                    Cursor="Hand"
                                                    ToolTip="Desactivar cliente"
                                                    Margin="Auto,0,0,0"
                                                    Command="{Binding DataContext.DesactivarClienteCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                    CommandParameter="{Binding Id}">
                                                <materialDesign:PackIcon Kind="Delete" Width="18" Height="18"/>
                                            </Button>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
