<UserControl x:Class="ProyectoRuben.Frontend.UCCaja"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:local="clr-namespace:ProyectoRuben.Frontend"
             mc:Ignorable="d"
             Background="{StaticResource LightGrayBrush}">

    <Grid Margin="20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="6*"/>
            <ColumnDefinition Width="20"/>
            <ColumnDefinition Width="4*"/>
        </Grid.ColumnDefinitions>

        <!-- PANEL IZQUIERDO: SELECCIÓN DE RESERVA Y CLIENTE -->
        <Border Grid.Column="0" Background="White" CornerRadius="12" Padding="20" Margin="0">
            <Border.Effect>
                <DropShadowEffect BlurRadius="15" ShadowDepth="2" Direction="270" Color="#000000" Opacity="0.08"/>
            </Border.Effect>

            <StackPanel VerticalAlignment="Top">
                <!-- ENCABEZADO -->
                <TextBlock Text="Caja - Punto de Venta" 
                           FontSize="24" 
                           FontWeight="SemiBold" 
                           Foreground="{StaticResource TextBrush}"
                           Margin="0,0,0,24"/>

                <!-- SECCIÓN: CARGAR RESERVA -->
                <TextBlock Text="Cargar Reserva del Día" 
                           FontSize="14" 
                           FontWeight="SemiBold" 
                           Foreground="{StaticResource TextBrush}"
                           Margin="0,0,0,12"/>

                <Border Background="{StaticResource MediumGrayBrush}" 
                        CornerRadius="8" 
                        Padding="12" 
                        Margin="0,0,0,16">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBox Grid.Column="0"
                                 x:Name="TextBoxReservaId"
                                 Text="{Binding ReservaIdBusqueda, Mode=TwoWay}"
                                 Background="White"
                                 BorderThickness="1"
                                 BorderBrush="#DFE6E9"
                                 Padding="12,8"
                                 Foreground="{StaticResource TextBrush}"
                                 PlaceholderText="ID de reserva"/>

                        <Button Grid.Column="1" 
                                Margin="8,0,0,0"
                                Background="{StaticResource AccentBrush}"
                                Foreground="White"
                                BorderThickness="0"
                                Padding="16,8"
                                Cursor="Hand"
                                Command="{Binding CargarReservaCommand}"
                                Style="{StaticResource MaterialDesignRaisedButton}">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="Magnify" Width="20" Height="20" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBlock Text="Cargar"/>
                            </StackPanel>
                        </Button>
                    </Grid>
                </Border>

                <!-- INFO CLIENTE CARGADO -->
                <Border Background="{StaticResource LightGrayBrush}" 
                        CornerRadius="8" 
                        Padding="12" 
                        Margin="0,0,0,24"
                        Visibility="{Binding ClienteSeleccionado, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <StackPanel>
                        <TextBlock Text="Cliente:" 
                                   FontSize="12" 
                                   Foreground="{StaticResource TextLightBrush}"
                                   Margin="0,0,0,4"/>
                        <TextBlock Text="{Binding ClienteSeleccionado.Nombre}" 
                                   FontSize="16" 
                                   FontWeight="SemiBold" 
                                   Foreground="{StaticResource TextBrush}"
                                   Margin="0,0,0,8"/>
                        <TextBlock Text="{Binding ClienteSeleccionado.Telefono}" 
                                   FontSize="12" 
                                   Foreground="{StaticResource TextLightBrush}"/>
                    </StackPanel>
                </Border>

                <!-- BOTONES DE ACCIONES RÁPIDAS -->
                <TextBlock Text="Agregar al Ticket" 
                           FontSize="14" 
                           FontWeight="SemiBold" 
                           Foreground="{StaticResource TextBrush}"
                           Margin="0,0,0,12"/>

                <StackPanel Orientation="Vertical" Margin="0,0,0,20">
                    <Button Height="50" 
                            Background="{StaticResource PrimaryBrush}"
                            Foreground="White"
                            BorderThickness="0"
                            Cursor="Hand"
                            Margin="0,0,0,8"
                            Command="{Binding AgregarExtraCommand}"
                            Style="{StaticResource MaterialDesignRaisedButton}">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <materialDesign:PackIcon Kind="Plus" Width="24" Height="24" VerticalAlignment="Center" Margin="0,0,12,0"/>
                            <TextBlock Text="Servicio Extra" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button Height="50" 
                            Background="{StaticResource SecondaryBrush}"
                            Foreground="White"
                            BorderThickness="0"
                            Cursor="Hand"
                            Command="{Binding AgregarExtraCommand}"
                            Style="{StaticResource MaterialDesignRaisedButton}">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <materialDesign:PackIcon Kind="Package" Width="24" Height="24" VerticalAlignment="Center" Margin="0,0,12,0"/>
                            <TextBlock Text="Producto Extra" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- SEPARADOR -->
        <Border Grid.Column="1" Background="{StaticResource MediumGrayBrush}"/>

        <!-- PANEL DERECHO: TICKET DE COMPRA -->
        <Border Grid.Column="2" Background="White" CornerRadius="12" Padding="16" Margin="0">
            <Border.Effect>
                <DropShadowEffect BlurRadius="15" ShadowDepth="2" Direction="270" Color="#000000" Opacity="0.08"/>
            </Border.Effect>

            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <!-- ENCABEZADO TICKET -->
                    <StackPanel Margin="0,0,0,16" HorizontalAlignment="Center">
                        <TextBlock Text="Peluquería Charo" 
                                   FontSize="14" 
                                   FontWeight="SemiBold" 
                                   Foreground="{StaticResource TextBrush}"
                                   HorizontalAlignment="Center"
                                   Margin="0,0,0,4"/>
                        <TextBlock Text="{Binding ClienteSeleccionado.Nombre}" 
                                   FontSize="12" 
                                   Foreground="{StaticResource TextLightBrush}"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>

                    <!-- LÍNEA SEPARADORA -->
                    <Border Height="1" Background="{StaticResource MediumGrayBrush}" Margin="0,0,0,12"/>

                    <!-- DETALLE DE LÍNEAS -->
                    <ItemsControl ItemsSource="{Binding LineasTicket}" Margin="0,0,0,12">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Descripcion}" 
                                                   FontSize="12" 
                                                   FontWeight="SemiBold" 
                                                   Foreground="{StaticResource TextBrush}"/>
                                        <TextBlock Text="{Binding Cantidad, StringFormat=x{0}}" 
                                                   FontSize="11" 
                                                   Foreground="{StaticResource TextLightBrush}"/>
                                    </StackPanel>

                                    <TextBlock Grid.Column="1" 
                                               Text="{Binding Importe, StringFormat=${0:F2}}" 
                                               FontSize="12" 
                                               FontWeight="SemiBold" 
                                               Foreground="{StaticResource AccentBrush}"
                                               HorizontalAlignment="Right"
                                               VerticalAlignment="Center"/>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- LÍNEA SEPARADORA -->
                    <Border Height="1" Background="{StaticResource MediumGrayBrush}" Margin="0,0,0,12"/>

                    <!-- SUBTOTAL Y DESCUENTO -->
                    <StackPanel Margin="0,0,0,12">
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0" 
                                       Text="Subtotal:" 
                                       FontSize="11" 
                                       Foreground="{StaticResource TextLightBrush}"/>
                            <TextBlock Grid.Column="1" 
                                       Text="{Binding Subtotal, StringFormat=${0:F2}}" 
                                       FontSize="11" 
                                       Foreground="{StaticResource TextBrush}"/>
                        </Grid>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="120"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0" 
                                       Text="Descuento:" 
                                       FontSize="11" 
                                       Foreground="{StaticResource TextLightBrush}"
                                       VerticalAlignment="Center"/>
                            <TextBox Grid.Column="1" 
                                     Text="{Binding Descuento, Mode=TwoWay, StringFormat=F2}" 
                                     Background="White"
                                     BorderThickness="1"
                                     BorderBrush="#DFE6E9"
                                     Padding="8"
                                     Foreground="{StaticResource TextBrush}"
                                     TextAlignment="Right"/>
                        </Grid>
                    </StackPanel>

                    <!-- LÍNEA SEPARADORA -->
                    <Border Height="2" Background="{StaticResource MediumGrayBrush}" Margin="0,0,0,16"/>

                    <!-- TOTAL GRANDE -->
                    <StackPanel HorizontalAlignment="Center" Margin="0,0,0,20">
                        <TextBlock Text="TOTAL A PAGAR" 
                                   FontSize="11" 
                                   Foreground="{StaticResource TextLightBrush}"
                                   HorizontalAlignment="Center"
                                   Margin="0,0,0,4"/>
                        <TextBlock Text="{Binding Total, StringFormat=${0:F2}}" 
                                   FontSize="32" 
                                   FontWeight="Bold" 
                                   Foreground="{StaticResource AccentBrush}"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>

                    <!-- MÉTODO DE PAGO -->
                    <TextBlock Text="Método de Pago:" 
                               FontSize="11" 
                               Foreground="{StaticResource TextLightBrush}"
                               Margin="0,0,0,8"/>

                    <ComboBox ItemsSource="{x:Static local:MetodoPagoItems}"
                              SelectedItem="{Binding MetodoPagoSeleccionado}"
                              Background="White"
                              BorderBrush="#DFE6E9"
                              BorderThickness="1"
                              Padding="8"
                              Foreground="{StaticResource TextBrush}"
                              Margin="0,0,0,20">
                    </ComboBox>

                    <!-- BOTÓN COBRAR -->
                    <Button Height="60" 
                            Background="{StaticResource AccentBrush}"
                            Foreground="White"
                            BorderThickness="0"
                            Cursor="Hand"
                            Command="{Binding CobrarCommand}"
                            Style="{StaticResource MaterialDesignRaisedButton}"
                            FontSize="16"
                            FontWeight="SemiBold">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <materialDesign:PackIcon Kind="CreditCard" Width="28" Height="28" VerticalAlignment="Center" Margin="0,0,12,0"/>
                            <TextBlock Text="COBRAR" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</UserControl>
