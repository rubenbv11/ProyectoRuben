<Window x:Class="ProyectoRuben.Frontend.AgregarReserva"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        mc:Ignorable="d"
        Loaded="AgregarReserva_Loaded"
        Title="Nueva Reserva" Height="480" Width="420"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize"
        Background="#F5F6F7">

    <Border Margin="20" Background="White" CornerRadius="12" Padding="24">
        <Border.Effect>
            <DropShadowEffect BlurRadius="15" ShadowDepth="2" Direction="270" Color="#000000" Opacity="0.08"/>
        </Border.Effect>

        <StackPanel VerticalAlignment="Center">

            <TextBlock Text="Crear Nueva Reserva" 
                       FontSize="22"
                       FontWeight="SemiBold"
                       Foreground="#2D3436"
                       HorizontalAlignment="Center" 
                       Margin="0,0,0,24"/>

            <TextBlock Text="Cliente" FontSize="12" Foreground="#636E72" Margin="0,0,0,4"/>
            <ComboBox x:Name="ComboClientes"
                      DisplayMemberPath="Nombre" 
                      SelectedValuePath="Id"
                      Height="40"
                      Padding="12,8"
                      Foreground="#2D3436"
                      Background="White"
                      BorderBrush="#DFE6E9"
                      BorderThickness="1"
                      Margin="0,0,0,16"/>

            <TextBlock Text="Servicio" FontSize="12" Foreground="#636E72" Margin="0,0,0,4"/>
            <ComboBox x:Name="ComboServicios"
                      DisplayMemberPath="Nombre" 
                      SelectedValuePath="Id"
                      Height="40"
                      Padding="12,8"
                      Foreground="#2D3436"
                      Background="White"
                      BorderBrush="#DFE6E9"
                      BorderThickness="1"
                      Margin="0,0,0,16"/>

            <Grid Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="Fecha" FontSize="12" Foreground="#636E72" Margin="0,0,0,4"/>
                    <DatePicker x:Name="PickerFecha"
                                Height="40"
                                Foreground="#2D3436"
                                Background="White"
                                BorderBrush="#DFE6E9"
                                BorderThickness="1"/>
                </StackPanel>

                <StackPanel Grid.Column="2">
                    <TextBlock Text="Hora" FontSize="12" Foreground="#636E72" Margin="0,0,0,4"/>
                    <materialDesign:TimePicker x:Name="PickerHora"
                                               Is24Hours="True"
                                               Height="40"
                                               Foreground="#2D3436"
                                               Background="White"
                                               BorderBrush="#DFE6E9"
                                               BorderThickness="1"/>
                </StackPanel>
            </Grid>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,24,0,0">
                <Button Content="Cancelar" 
                        Background="Transparent"
                        Foreground="#636E72"
                        BorderThickness="1"
                        BorderBrush="#DFE6E9"
                        Padding="20,10"
                        Cursor="Hand"
                        IsCancel="True" 
                        Click="Cancelar_Click"/>

                <Button Content="Guardar" 
                        Background="#D4A574"
                        Foreground="White"
                        BorderThickness="0"
                        Padding="24,10"
                        Cursor="Hand"
                        Margin="12,0,0,0"
                        IsDefault="True" 
                        Click="Guardar_Click"/>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
