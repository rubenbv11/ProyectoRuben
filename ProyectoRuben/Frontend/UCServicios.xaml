<UserControl x:Class="ProyectoRuben.Frontend.UCServicios"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             mc:Ignorable="d" 
             Background="{StaticResource LightGrayBrush}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ENCABEZADO -->
        <Border Grid.Row="0" Background="White" Padding="32,24" BorderThickness="0,0,0,1" BorderBrush="{StaticResource MediumGrayBrush}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Título y descripción -->
                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <TextBlock Text="Catálogo de Servicios" 
                               FontSize="28" 
                               FontWeight="SemiBold" 
                               Foreground="{StaticResource TextBrush}"/>

                    <TextBlock Text="Visualiza y administra todos los servicios ofrecidos"
                               FontSize="13"
                               Foreground="{StaticResource TextLightBrush}"
                               Margin="0,4,0,0"/>
                </StackPanel>

                <!-- Botón Nuevo Servicio -->
                <Button Grid.Column="1" 
        Style="{StaticResource MaterialDesignRaisedButton}"
        VerticalAlignment="Center"
        Background="{StaticResource AccentBrush}"
        BorderBrush="{StaticResource AccentBrush}"
        Foreground="White"
        Height="40"
        Padding="16,0"
        Cursor="Hand"
        FontSize="13"
        FontWeight="SemiBold"
        Command="{Binding AgregarServicioCommand}">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <materialDesign:PackIcon Kind="Plus" Width="18" Height="18" Margin="0,0,8,0" VerticalAlignment="Center"/>
                        <TextBlock Text="Nuevo Servicio" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </Grid>
        </Border>

        <!-- CONTENIDO PRINCIPAL -->
        <Grid Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- BARRA DE BÚSQUEDA -->
            <Border Grid.Row="0" Background="White" Padding="32,16" BorderThickness="0,0,0,1" BorderBrush="{StaticResource MediumGrayBrush}">
                <TextBox Text="{Binding FiltroNombre, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         Height="40"
                         Padding="12,8"
                         Foreground="{StaticResource TextBrush}"
                         Background="White"
                         BorderBrush="{StaticResource MediumGrayBrush}"
                         BorderThickness="1"
                         FontSize="13"
                         MaxWidth="400"
                         HorizontalAlignment="Left">
                    <TextBox.Template>
                        <ControlTemplate TargetType="TextBox">
                            <Border BorderBrush="{TemplateBinding BorderBrush}" 
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="6"
                                    Background="{TemplateBinding Background}">
                                <Grid>
                                    <materialDesign:PackIcon Kind="Magnify" 
                                                             Foreground="{StaticResource TextLightBrush}"
                                                             Width="20" Height="20"
                                                             Margin="10,0,0,0"
                                                             VerticalAlignment="Center"/>
                                    <ScrollViewer Margin="36,0,10,0" x:Name="PART_ContentHost" VerticalAlignment="Center"/>
                                </Grid>
                            </Border>
                        </ControlTemplate>
                    </TextBox.Template>
                </TextBox>
            </Border>

            <!-- LISTA DE SERVICIOS O ESTADO VACÍO -->
            <Grid Grid.Row="1">
                <!-- Estado Vacío -->
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Visibility="{Binding EstaVacio, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <Border Width="80" Height="80" Background="{StaticResource MediumGrayBrush}" CornerRadius="40" HorizontalAlignment="Center" Margin="0,0,0,16">
                        <materialDesign:PackIcon Kind="Tools" 
                                                 Foreground="White"
                                                 Width="40" Height="40"
                                                 VerticalAlignment="Center"
                                                 HorizontalAlignment="Center"/>
                    </Border>

                    <TextBlock Text="Sin servicios registrados" 
                               FontSize="18" 
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextBrush}"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,8"/>

                    <TextBlock Text="Comienza agregando tu primer servicio"
                               FontSize="13"
                               Foreground="{StaticResource TextLightBrush}"
                               HorizontalAlignment="Center"/>
                </StackPanel>

                <!-- Lista de Servicios -->
                <ScrollViewer Visibility="{Binding EstaVacio, Converter={StaticResource BooleanToVisibilityConverter}, ConverterParameter=Invert}">
                    <ItemsControl ItemsSource="{Binding ListaServiciosView}" Padding="32,24">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel Orientation="Horizontal" Width="{Binding ActualWidth, RelativeSource={RelativeSource AncestorType=ItemsControl}}" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>

                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <!-- TARJETA DE SERVICIO -->
                                <Border Width="320" Margin="0,0,24,24"
                                        Background="White"
                                        CornerRadius="12"
                                        Padding="20">
                                    <Border.Effect>
                                        <DropShadowEffect BlurRadius="15" ShadowDepth="2" Direction="270" Color="#000000" Opacity="0.08"/>
                                    </Border.Effect>

                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <!-- ICONO Y NOMBRE -->
                                        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,16">
                                            <Border Width="50" Height="50" Background="{StaticResource AccentBrush}" CornerRadius="8" Margin="0,0,12,0">
                                                <materialDesign:PackIcon Kind="Scissors" 
                                                                         Foreground="White"
                                                                         Width="28" Height="28"
                                                                         VerticalAlignment="Center"
                                                                         HorizontalAlignment="Center"/>
                                            </Border>
                                            <StackPanel VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Nombre}"
                                                           FontSize="16"
                                                           FontWeight="SemiBold"
                                                           Foreground="{StaticResource TextBrush}"
                                                           TextTrimming="CharacterEllipsis"/>
                                                <TextBlock Text="{Binding Categoria}" 
                                                           FontSize="11"
                                                           Foreground="{StaticResource TextLightBrush}"
                                                           Margin="0,2,0,0"/>
                                            </StackPanel>
                                        </StackPanel>

                                        <!-- DESCRIPCIÓN -->
                                        <TextBlock Grid.Row="1"
                                                   Text="{Binding Descripcion}"
                                                   FontSize="12"
                                                   Foreground="{StaticResource TextLightBrush}"
                                                   TextTrimming="CharacterEllipsis"
                                                   TextWrapping="Wrap"
                                                   MaxHeight="48"
                                                   Margin="0,0,0,12"/>

                                        <!-- SEPARADOR -->
                                        <Rectangle Grid.Row="2" Height="1" Fill="{StaticResource MediumGrayBrush}" Margin="0,0,0,12" VerticalAlignment="Top"/>

                                        <!-- CHIPS: COSTO Y DURACIÓN -->
                                        <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,0,0,12">
                                            <!-- Costo -->
                                            <Border Padding="12,6" Background="{StaticResource LightGrayBrush}" CornerRadius="4" Margin="0,0,8,0">
                                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                    <materialDesign:PackIcon Kind="CurrencyUsd" 
                                                                             Foreground="{StaticResource AccentBrush}"
                                                                             Width="14" Height="14"
                                                                             Margin="0,0,6,0"/>
                                                    <TextBlock Text="{Binding Costo, StringFormat='C'}" 
                                                               FontSize="11"
                                                               FontWeight="SemiBold"
                                                               Foreground="{StaticResource TextBrush}"/>
                                                </StackPanel>
                                            </Border>

                                            <!-- Duración -->
                                            <Border Padding="12,6" Background="{StaticResource LightGrayBrush}" CornerRadius="4">
                                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                    <materialDesign:PackIcon Kind="ClockOutline" 
                                                                             Foreground="{StaticResource TextLightBrush}"
                                                                             Width="14" Height="14"
                                                                             Margin="0,0,6,0"/>
                                                    <TextBlock Text="{Binding Duracion, StringFormat='{}{0} min'}" 
                                                          
                                                               FontSize="11"
                                                                               Foreground="{StaticResource TextLightBrush}"/>
                                                </StackPanel>
                                            </Border>
                                        </StackPanel>

                                        <!-- BOTONES DE ACCIÓN -->
                                        <StackPanel Grid.Row="4" Orientation="Horizontal">
                                            <!-- Editar -->
                                            <Button Width="40" Height="40"
                                                    Background="{StaticResource LightGrayBrush}"
                                                    Foreground="{StaticResource TextBrush}"
                                                    BorderThickness="0"
                                                    Cursor="Hand"
                                                    ToolTip="Editar servicio"
                                                    Margin="0,0,8,0"
                                                    Command="{Binding DataContext.EditarServicioCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                    CommandParameter="{Binding}">
                                                <materialDesign:PackIcon Kind="Pencil" Width="18" Height="18"/>
                                            </Button>

                                            <!-- Desactivar -->
                                            <Button Width="40" Height="40"
                                                    Background="#FFE0E0"
                                                    Foreground="#D63031"
                                                    BorderThickness="0"
                                                    Cursor="Hand"
                                                    ToolTip="Desactivar servicio"
                                                    Margin="Auto,0,0,0"
                                                    Command="{Binding DataContext.DesactivarServicioCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                    CommandParameter="{Binding Id}">
                                                <materialDesign:PackIcon Kind="Delete" Width="18" Height="18"/>
                                            </Button>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
